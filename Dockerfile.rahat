FROM public.ecr.aws/docker/library/node:20-alpine3.19 AS deps
WORKDIR /usr/src/app
COPY ./dist/apps/rahat/package.json ./
RUN npm install -g pnpm@9.15.2 && pnpm install

FROM public.ecr.aws/docker/library/node:20-alpine3.19 AS builder
WORKDIR /usr/src/app
COPY ./dist/apps/rahat/ ./
COPY --from=deps /usr/src/app/node_modules ./node_modules
RUN npm install -g pnpm@9.15.2 && pnpm prisma generate
CMD [ "node", "main.js" ]
