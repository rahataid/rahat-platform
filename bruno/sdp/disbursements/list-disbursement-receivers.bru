meta {
  name: list-disbursement-receivers
  type: http
  seq: 5
}

get {
  url: {{sdp_url}}/disbursements/{{disbursement_id}}/receivers
  body: none
  auth: bearer
}

params:query {
  ~page: 1
  ~page_limit: 20
  ~sort: updated_at
  ~direction: desc
}

auth:bearer {
  token: {{sdp_access_token}}
}
