meta {
  name: mfa
  type: http
  seq: 3
}

post {
  url: {{sdp_url}}/mfa
  body: json
  auth: bearer
}

auth:bearer {
  token: {{sdp_access_token}}
}

body:json {
  {
    "mfa_code": "123456",
    "remember_me": false
  }
}

script:post-response {
  const body = res.getBody();
  if (body.token) {
    bru.setEnvVar("sdp_access_token", body.token);
  }
}
