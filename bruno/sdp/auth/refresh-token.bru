meta {
  name: refresh-token
  type: http
  seq: 2
}

post {
  url: {{sdp_url}}/refresh-token
  body: none
  auth: bearer
}

auth:bearer {
  token: {{sdp_access_token}}
}

script:post-response {
  const body = res.getBody();
  if (body.token) {
    bru.setEnvVar("sdp_access_token", body.token);
  }
}
