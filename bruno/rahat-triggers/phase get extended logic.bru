meta {
  name: phase get extended logic
  type: http
  seq: 49
}

post {
  url: {{url}}/projects/{{uuid}}/actions
  body: json
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "action": "ms.phases.getExtendedLogic",
    "payload": {
      "uuid": "{{phaseId}}"
    }
  }
}
