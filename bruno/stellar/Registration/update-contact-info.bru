meta {
  name: update-contact-info
  type: http
  seq: 3
}

patch {
  url: {{sdp_url}}/registration/contact-info
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{sdp_token}}
  Content-Type: application/json
}

body:json {
  {
    "phone_number": "+1234567890",
    "email": "receiver@example.com"
  }
}
